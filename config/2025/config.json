{
  "$schema": "https://frc2713.github.io/QRScout/schema.json",
  "title": "QRScout",
  "page_title": "Rebuilt Team 8114 -- 2026 State",
  "delimiter": "\t",
  "teamNumber": 8114,
  "sections": [
    {
      "name": "Prematch",
      "fields": [
        { "title": "Scouter Initials", "type": "text", "required": true, "code": "scouter", "defaultValue": "" },
        { "title": "Match Number", "type": "number", "required": true, "code": "matchNumber", "defaultValue": 1 },
        {
          "title": "Robot",
          "type": "select",
          "required": true,
          "code": "robot",
          "defaultValue": "R1",
          "choices": { "R1": "Red 1", "R2": "Red 2", "R3": "Red 3", "B1": "Blue 1", "B2": "Blue 2", "B3": "Blue 3" }
        },
        { "title": "Team Number", "type": "number", "required": true, "code": "teamNumber", "defaultValue": 0, "min": 0, "max": 19999 },
        {
          "title": "Starting Position",
          "type": "select",
          "required": true,
          "code": "startPos",
          "defaultValue": "H",
          "choices": {
            "OT": "Outpost Trench",
            "OB": "Outpost Bump",
            "H": "Hub",
            "DB": "Depot Bump",
            "DT": "Depot Trench"
          }
        }
      ]
    },
    {
      "name": "Autonomous",
      "fields": [
        {
          "title": "Auton Path",
          "type": "select",
          "required": false,
          "code": "APath",
          "defaultValue": "TNT",
          "choices": {
            "TNT": "TNT",
            "TNB": "TNB",
            "BNB": "BNB",
            "BNT": "BNT",
            "AZ": "AZ"
          }
        },
        { "title": "Cleared Depot", "type": "boolean", "required": false, "code": "AClDep", "defaultValue": false },
        {
          "title": "Balls Scored",
          "type": "select",
          "required": false,
          "code": "ABallsSc",
          "defaultValue": "0",
          "choices": {
            "0": "0",
            "<10": "Less than 10",
            "11-20": "11 to 20",
            "21-30": "21 to 30",
            ">30": "More than 30"
          }
        },
        { "title": "Climbed", "type": "boolean", "required": false, "code": "AClimb", "defaultValue": false }
      ]
    },
    {
      "name": "Teleop",
      "fields": [
        {
          "title": "Shooting Throughput",
          "type": "select",
          "required": false,
          "code": "TShootTP",
          "defaultValue": "M",
          "choices": { "H": "High", "M": "Medium", "L": "Low" }
        },
        {
          "title": "Neutral Zone Passing Effectiveness",
          "type": "select",
          "required": false,
          "code": "TNZPass",
          "defaultValue": "M",
          "choices": { "H": "High", "M": "Medium", "L": "Low" }
        },
        {
          "title": "Opposing Alliance Passing Effectiveness",
          "type": "select",
          "required": false,
          "code": "TOAPass",
          "defaultValue": "M",
          "choices": { "H": "High", "M": "Medium", "L": "Low" }
        },
        {
          "title": "Defense Skill",
          "type": "select",
          "required": false,
          "code": "TDefSkill",
          "defaultValue": "M",
          "choices": { "H": "High", "M": "Medium", "L": "Low" }
        },
        { "title": "Fouls", "type": "boolean", "required": false, "code": "TFouls", "defaultValue": false }
      ]
    },
    {
      "name": "Endgame",
      "fields": [
        { "title": "Climbed", "type": "boolean", "required": false, "code": "EClimb", "defaultValue": false },
        {
          "title": "Climb Level",
          "type": "select",
          "required": false,
          "code": "EClimbLvl",
          "defaultValue": "None",
          "choices": { "None": "None", "L1": "Level 1", "L2": "Level 2", "L3": "Level 3" }
        }
      ]
    },
    {
      "name": "Postmatch",
      "fields": [
        { "title": "Died", "type": "boolean", "required": false, "code": "PMDied", "defaultValue": false },
        { "title": "Beached", "type": "boolean", "required": false, "code": "PMBeach", "defaultValue": false },
        { "title": "Fouls", "type": "boolean", "required": false, "code": "PMFouls", "defaultValue": false },
        { "title": "Comments", "type": "text", "required": false, "code": "comments", "defaultValue": "", "min": 0, "max": 100 }
      ]
    }
  ]
}
